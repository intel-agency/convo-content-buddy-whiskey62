# Copy this file to .env and fill in your values.
# The .env file is gitignored and should never be committed.

# Gemini API Key (required)
GEMINI_API_KEY=

# PostgreSQL credentials for local development
PGHOST=localhost
PGDATABASE=convocontentbuddy
PGUSER=postgres
PGPASSWORD=

# Override the full connection string if needed (takes precedence over individual vars)
# ConnectionStrings__PostgreSQL=Host=localhost;Database=convocontentbuddy;Username=postgres;Password=
