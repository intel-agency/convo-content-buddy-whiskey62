{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore.Components": "Warning"
    }
  },
  "SignalR": {
    "HubUrl": "http://localhost:5000/buddyhub",
    "ReconnectDelayMs": 2000,
    "MaxReconnectAttempts": 10
  },
  "SpeechRecognition": {
    "Language": "en-US",
    "Continuous": true,
    "InterimResults": true,
    "MaxAlternatives": 3
  },
  "TranscriptBuffer": {
    "DebounceMs": 500,
    "MinLength": 10,
    "MaxSize": 1000
  }
}
