{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.SemanticKernel": "Debug"
    }
  },
  "AllowedHosts": "*",
  "SemanticKernel": {
    "Provider": "Gemini",
    "ModelId": "gemini-2.5-flash",
    "EmbeddingModelId": "gemini-embedding-001"
  },
  "EmbeddingProfile": {
    "ModelName": "gemini-embedding-001",
    "Dimensions": 1536
  },
  "PostgreSQL": {
    "ConnectionString": "Host=localhost;Database=convocontentbuddy;Username=postgres;Password="
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "SignalR": {
    "HubPath": "/buddyhub",
    "EnableRedisBackplane": true
  },
  "HybridRetriever": {
    "MaxVectorResults": 5,
    "MaxGraphDepth": 3,
    "ConfidenceThreshold": 0.85
  },
  "Failover": {
    "EnableSafeMode": true,
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 2
  }
}
