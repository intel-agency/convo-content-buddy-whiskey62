{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "SemanticKernel": {
    "Provider": "Gemini",
    "EmbeddingModelId": "text-embedding-004",
    "ApiKey": "${GEMINI_API_KEY}"
  },
  "Qdrant": {
    "Host": "localhost",
    "Port": 6334,
    "CollectionName": "leetcode_problems",
    "VectorSize": 768,
    "RecreateCollection": false
  },
  "PostgreSQL": {
    "ConnectionString": "Host=localhost;Database=convocontentbuddy;Username=postgres;Password=postgres"
  },
  "Seeder": {
    "BatchSize": 100,
    "MaxDegreeOfParallelism": 4,
    "SourceDirectory": "./data/leetcode",
    "EnableIncrementalUpdates": true
  }
}
